# ─────────────────────────────────────────────────────────────────────────────
# IPO Views — environment variables
# Copy to `.env` for local dev. In production, set these in the Vercel dashboard
# (Project → Settings → Environment Variables). Do NOT commit your real .env.
# ─────────────────────────────────────────────────────────────────────────────

# Google Sheets GMP feed — your sheet "Published to web".
# Accepts EITHER a CSV url or a gviz JSON url (auto-detected):
#   CSV : https://docs.google.com/spreadsheets/d/e/<ID>/pub?gid=0&single=true&output=csv
#   JSON: https://docs.google.com/spreadsheets/d/<ID>/gviz/tq?tqx=out:json&sheet=GMP
SHEETS_GMP_URL=

# Google Apps Script Web App URL (the /admin form POSTs here to write the sheet).
#   e.g. https://script.google.com/macros/s/AKfycb.../exec
SHEETS_WEBHOOK_URL=

# Password for the /admin page. MUST match the Apps Script "ADMIN_PASSWORD"
# Script Property — the server uses this same value to authorize webhook writes.
ADMIN_PASSWORD=

# Vercel Deploy Hook — used by GitHub Actions to trigger a rebuild after new data.
# Get it from: Vercel → Project → Settings → Git → Deploy Hooks (create one for `main`).
# NOTE: this one is a GITHUB SECRET (repo → Settings → Secrets → Actions),
# not a Vercel env var.
VERCEL_DEPLOY_HOOK=
