---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Something went wrong (500) | IPO Views';
const description = 'An unexpected error occurred on our end. Please try again in a moment.';
---

<BaseLayout title={title} description={description} noindex>
  <section class="hero-surface">
    <div class="container-page grid min-h-[60vh] place-items-center py-16 text-center sm:py-24">
      <div class="mx-auto w-full max-w-[560px]">
        <p class="num text-6xl font-bold tracking-tight text-warn sm:text-7xl">500</p>
        <h1 class="page-title mt-4">Something went wrong on our end</h1>
        <p class="mx-auto mt-4 max-w-md text-text-muted">
          We hit an unexpected error while loading this page — it's not you. The issue has
          been logged. Please try again in a moment.
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/" class="btn btn-primary">← Back to homepage</a>
          <button type="button" onclick="window.location.reload()" class="btn btn-ghost">
            Try again
          </button>
        </div>

        <p class="mt-8 text-sm text-text-muted">
          If this keeps happening, let us know at
          <a href="mailto:contact@ipoviews.com" class="text-info hover:text-text">contact@ipoviews.com</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
