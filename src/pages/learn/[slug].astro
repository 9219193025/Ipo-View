---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  ARTICLES, getArticle, relatedArticles, readTimeMinutes, metaDescription, type Block,
} from '../../data/articles';

export function getStaticPaths() {
  return ARTICLES.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = getArticle(slug!);
if (!article) return Astro.redirect('/learn');

const readTime = readTimeMinutes(article);
const description = metaDescription(article);
const related = relatedArticles(article.slug, 3);

const title = `${article.title} | IPO Views`;
const canonical = `/learn/${article.slug}`;

// Article JSON-LD for SEO.
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description,
  articleSection: article.category,
  author: { '@type': 'Organization', name: 'IPO Views' },
  publisher: {
    '@type': 'Organization',
    name: 'IPO Views',
    url: 'https://ipoviews.com',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(canonical, Astro.site).href,
  },
  inLanguage: 'en-IN',
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Learn', item: new URL('/learn', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: article.title, item: new URL(canonical, Astro.site).href },
  ],
};

function isP(b: Block): b is { p: string } { return 'p' in b; }
function isSub(b: Block): b is { sub: string } { return 'sub' in b; }
function isList(b: Block): b is { list: string[] } { return 'list' in b; }
function isOl(b: Block): b is { ol: string[] } { return 'ol' in b; }
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogType="article"
  jsonLd={[articleLd, breadcrumbLd]}
>
  <div class="container-page py-8 sm:py-10">
    <!-- breadcrumb -->
    <nav class="mb-6 text-xs text-text-faint" aria-label="Breadcrumb">
      <a href="/learn" class="hover:text-text">Learn</a>
      <span class="mx-1.5">/</span>
      <span class="text-text-muted">{article.category}</span>
    </nav>

    <div class="lg:grid lg:grid-cols-[1fr_240px] lg:gap-10">
      <!-- ARTICLE -->
      <article class="mx-auto w-full max-w-[680px] lg:mx-0">
        <span class="pill border border-brand/50 text-brand-hover">{article.category}</span>
        <h1 class="page-title mt-3">{article.title}</h1>
        <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-text-faint">
          <span class="num">{readTime} min read</span>
          <span aria-hidden="true">·</span>
          <span>IPO Views Education</span>
        </div>

        <p class="mt-6 text-lg leading-relaxed text-text-muted">{article.intro}</p>

        {article.sections.map((s) => (
          <section class="mt-10 scroll-mt-24" id={s.id}>
            <h2 class="text-h2 font-bold">
              <a href={`#${s.id}`} class="hover:text-brand-hover">{s.heading}</a>
            </h2>
            <div class="mt-3 flex flex-col gap-4">
              {s.blocks.map((b) => (
                <>
                  {isP(b) && <p class="leading-relaxed text-text">{b.p}</p>}
                  {isSub(b) && <h3 class="text-h3 font-semibold text-text">{b.sub}</h3>}
                  {isList(b) && (
                    <ul class="ml-1 flex flex-col gap-2">
                      {b.list.map((li) => (
                        <li class="flex gap-2.5 text-text">
                          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"></span>
                          <span class="leading-relaxed">{li}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                  {isOl(b) && (
                    <ol class="flex flex-col gap-3">
                      {b.ol.map((li, i) => (
                        <li class="flex gap-3 text-text">
                          <span class="num grid h-6 w-6 shrink-0 place-items-center rounded-full border border-border bg-surface-2 text-xs font-semibold text-text-muted">{i + 1}</span>
                          <span class="leading-relaxed pt-0.5">{li}</span>
                        </li>
                      ))}
                    </ol>
                  )}
                </>
              ))}
            </div>
          </section>
        ))}

        <!-- CTA -->
        <div class="card mt-12 flex flex-col items-start gap-3 p-6 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h2 class="text-h3 font-semibold">See it live</h2>
            <p class="mt-1 text-sm text-text-muted">Live GMP, subscription and listing estimates for every open IPO.</p>
          </div>
          <a href="/" class="btn btn-primary shrink-0">Check Live IPO GMP →</a>
        </div>

        <!-- RELATED -->
        {related.length > 0 && (
          <section class="mt-12">
            <h2 class="text-h2 font-bold">Related articles</h2>
            <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-3">
              {related.map((r) => (
                <a href={`/learn/${r.slug}`} class="card card-link flex flex-col p-4">
                  <span class="pill self-start border border-info/50 text-info">{r.category}</span>
                  <h3 class="mt-2.5 text-sm font-semibold leading-snug">{r.title}</h3>
                  <span class="num mt-3 text-xs text-text-faint">{readTimeMinutes(r)} min read →</span>
                </a>
              ))}
            </div>
          </section>
        )}
      </article>

      <!-- TOC (desktop sidebar) -->
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <p class="label mb-3">On this page</p>
          <nav aria-label="Table of contents">
            <ul class="flex flex-col gap-2 border-l border-border">
              {article.sections.map((s) => (
                <li>
                  <a href={`#${s.id}`} class="-ml-px block border-l-2 border-transparent pl-3 text-sm text-text-muted transition-colors hover:border-brand hover:text-text">{s.heading}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
