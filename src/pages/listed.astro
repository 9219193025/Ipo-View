---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getIndiaIPOs } from '../data/index';
import { rupee, pct, times, fmtDate, listingGain, gmpAccuracy, siteAccuracy } from '../data/helpers';

const listed = (await getIndiaIPOs())
  .filter((i) => i.status === 'listed')
  .sort((a, b) => (b.listingDate < a.listingDate ? -1 : 1));
const site = siteAccuracy(listed);
const years = [...new Set(listed.map((i) => i.listingDate.slice(0, 4)))].sort().reverse();

// precompute rows
const rows = listed.map((i) => {
  const gain = listingGain(i) ?? 0;
  const acc = gmpAccuracy(i);
  return {
    slug: i.slug,
    name: i.name,
    type: i.type,
    exchange: i.exchange,
    year: i.listingDate.slice(0, 4),
    listingDate: i.listingDate,
    issue: i.priceBand.max,
    listing: i.listingPrice ?? 0,
    gain,
    sub: i.subscription.total,
    accuracy: acc?.score ?? 0,
  };
});

const winners = rows.filter((r) => r.gain >= 0).length;

const title = 'Listed IPOs — Actual Listing Gains & GMP Accuracy | IPO Views';
const description = `All recently listed IPOs with actual listing gains and our GMP accuracy score. Overall accuracy ${site.score}% across ${site.count} IPOs. Filter by year, exchange and gain/loss.`;
---

<BaseLayout title={title} description={description}>
  <div class="container-page py-8 sm:py-10">
    <h1 class="page-title">Listed IPOs</h1>
    <p class="mt-2 max-w-2xl text-text-muted">
      Every listed IPO with its actual listing gain — and how accurate our GMP-based estimate
      was. Honest scorekeeping, because trust is the product.
    </p>

    <!-- accuracy banner (feature #1) -->
    <div id="accuracy" class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="card p-4">
        <p class="label">Site GMP accuracy</p>
        <p class={`num mt-1 text-2xl font-bold ${site.score >= 80 ? 'text-pos' : site.score >= 50 ? 'text-warn' : 'text-neg'}`}>{site.score}%</p>
        <p class="mt-1 text-xs text-text-faint">{site.count} IPOs tracked</p>
      </div>
      <div class="card p-4">
        <p class="label">Listed IPOs</p>
        <p class="num mt-1 text-2xl font-bold">{listed.length}</p>
      </div>
      <div class="card p-4">
        <p class="label">Positive listings</p>
        <p class="num mt-1 text-2xl font-bold text-pos">{winners}</p>
        <p class="mt-1 text-xs text-text-faint">of {listed.length}</p>
      </div>
      <div class="card p-4">
        <p class="label">Avg listing gain</p>
        <p class="num mt-1 text-2xl font-bold text-pos">{pct(rows.reduce((a, r) => a + r.gain, 0) / (rows.length || 1))}</p>
      </div>
    </div>

    <!-- filters -->
    <div class="mt-6 flex flex-wrap items-end gap-3" data-listed>
      <div>
        <label class="label" for="f-year">Year</label>
        <select id="f-year" class="mt-1 rounded-[var(--radius-control)] border border-border bg-bg px-3 py-2 text-sm">
          <option value="">All years</option>
          {years.map((y) => <option value={y}>{y}</option>)}
        </select>
      </div>
      <div>
        <label class="label" for="f-exchange">Exchange</label>
        <select id="f-exchange" class="mt-1 rounded-[var(--radius-control)] border border-border bg-bg px-3 py-2 text-sm">
          <option value="">All</option>
          <option value="NSE">NSE</option>
          <option value="BSE">BSE</option>
        </select>
      </div>
      <div>
        <label class="label" for="f-result">Result</label>
        <select id="f-result" class="mt-1 rounded-[var(--radius-control)] border border-border bg-bg px-3 py-2 text-sm">
          <option value="">Gain &amp; loss</option>
          <option value="gain">Gain only</option>
          <option value="loss">Loss only</option>
        </select>
      </div>
      <div>
        <label class="label" for="f-sort">Sort by</label>
        <select id="f-sort" class="mt-1 rounded-[var(--radius-control)] border border-border bg-bg px-3 py-2 text-sm">
          <option value="date">Listing date</option>
          <option value="gain">Listing gain</option>
          <option value="sub">Subscription</option>
          <option value="accuracy">GMP accuracy</option>
        </select>
      </div>
      <p id="f-count" class="num ml-auto text-sm text-text-muted"></p>
    </div>

    <!-- table -->
    <div class="mt-4 overflow-x-auto rounded-[var(--radius-card)] border border-border">
      <table class="w-full min-w-[760px] text-sm">
        <thead class="bg-surface-2 text-left">
          <tr class="label">
            <th class="px-4 py-3 font-medium">IPO</th>
            <th class="px-4 py-3 text-right font-medium">Issue</th>
            <th class="px-4 py-3 text-right font-medium">Listed</th>
            <th class="px-4 py-3 text-right font-medium">Listing gain</th>
            <th class="px-4 py-3 text-right font-medium">Subscription</th>
            <th class="px-4 py-3 text-right font-medium">GMP accuracy</th>
            <th class="px-4 py-3 text-right font-medium">Date</th>
          </tr>
        </thead>
        <tbody id="listed-body">
          {rows.map((r) => (
            <tr
              class="border-t border-border hover:bg-surface-2/40"
              data-row
              data-year={r.year}
              data-exchange={r.exchange}
              data-gain={r.gain}
              data-sub={r.sub}
              data-accuracy={r.accuracy}
              data-date={r.listingDate}
            >
              <td class="px-4 py-3">
                <a href={`/ipo/${r.slug}`} class="font-medium hover:text-brand-hover">{r.name}</a>
                <span class={`pill ml-2 ${r.type === 'sme' ? 'text-warn border border-warn/40' : 'text-info border border-info/40'}`}>{r.type === 'sme' ? 'SME' : 'MB'}</span>
              </td>
              <td class="num px-4 py-3 text-right">{rupee(r.issue)}</td>
              <td class="num px-4 py-3 text-right">{rupee(r.listing)}</td>
              <td class={`num px-4 py-3 text-right font-bold ${r.gain >= 0 ? 'text-pos' : 'text-neg'}`}>{pct(r.gain)}</td>
              <td class="num px-4 py-3 text-right">{times(r.sub)}</td>
              <td class={`num px-4 py-3 text-right font-semibold ${r.accuracy >= 80 ? 'text-pos' : r.accuracy >= 50 ? 'text-warn' : 'text-neg'}`}>{r.accuracy}%</td>
              <td class="num px-4 py-3 text-right text-text-muted">{fmtDate(r.listingDate).slice(0, 6)}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p id="empty-msg" class="hidden p-6 text-center text-text-muted">No IPOs match these filters.</p>
    </div>
  </div>

  <script>
    const root = document.querySelector('[data-listed]');
    const body = document.getElementById('listed-body');
    if (root && body) {
      const fYear = root.querySelector('#f-year') as HTMLSelectElement;
      const fEx = root.querySelector('#f-exchange') as HTMLSelectElement;
      const fRes = root.querySelector('#f-result') as HTMLSelectElement;
      const fSort = root.querySelector('#f-sort') as HTMLSelectElement;
      const count = root.querySelector('#f-count') as HTMLElement;
      const empty = document.getElementById('empty-msg') as HTMLElement;
      const rows = Array.from(body.querySelectorAll('[data-row]')) as HTMLElement[];

      function apply() {
        let visible = 0;
        rows.forEach((r) => {
          const gain = parseFloat(r.dataset.gain || '0');
          let show = true;
          if (fYear.value && r.dataset.year !== fYear.value) show = false;
          if (fEx.value && !(r.dataset.exchange || '').includes(fEx.value)) show = false;
          if (fRes.value === 'gain' && gain < 0) show = false;
          if (fRes.value === 'loss' && gain >= 0) show = false;
          r.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        const key = fSort.value;
        const sorted = [...rows].sort((a, b) => {
          if (key === 'date') return (b.dataset.date || '').localeCompare(a.dataset.date || '');
          const va = parseFloat(a.dataset[key] || '0');
          const vb = parseFloat(b.dataset[key] || '0');
          return vb - va;
        });
        sorted.forEach((r) => body!.appendChild(r));

        count.textContent = visible + ' of ' + rows.length;
        empty.classList.toggle('hidden', visible !== 0);
      }

      [fYear, fEx, fRes, fSort].forEach((el) => el.addEventListener('change', apply));
      apply();
    }
  </script>
</BaseLayout>
