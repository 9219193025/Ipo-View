---
// SSR so live Google-Sheets GMP edits appear without a rebuild.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import IpoCard from '../components/IpoCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import IpoCalculator from '../components/IpoCalculator.astro';
import NewsSection from '../components/NewsSection.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import { HOMEPAGE_FAQS } from '../data/faqs';
import { getIndiaIPOs, getGmpFreshness } from '../data/index';
import {
  rupee, pct, marketSentiment, siteAccuracy, byGmpDesc, listingGain, listingEstimate,
} from '../data/helpers';

const all = await getIndiaIPOs();
const open = all.filter((i) => i.status === 'open').sort(byGmpDesc);
const upcoming = all.filter((i) => i.status === 'upcoming').sort(byGmpDesc);
const recentlyListed = all
  .filter((i) => i.status === 'listed')
  .sort((a, b) => (b.listingDate < a.listingDate ? -1 : 1))
  .slice(0, 4);

const topGmp = [...all].filter((i) => i.status !== 'listed').sort(byGmpDesc)[0];
const mood = marketSentiment(all);
const accuracy = siteAccuracy(all);
const avgSub = open.length ? open.reduce((a, i) => a + i.subscription.total, 0) / open.length : 0;

// GMP freshness from the Google Sheet (India = Sheets-only).
const fresh = await getGmpFreshness();
function freshnessLabel(): string {
  if (!fresh.configured) return 'Live GMP via Google Sheets';
  if (fresh.ageMinutes == null) return 'GMP synced';
  if (fresh.ageMinutes < 1) return 'GMP updated just now';
  if (fresh.ageMinutes < 60) return `GMP updated ${fresh.ageMinutes} min ago`;
  return `GMP updated ${Math.round(fresh.ageMinutes / 60)}h ago`;
}

const moodTone: Record<string, string> = {
  pos: 'text-pos border-pos/50',
  warn: 'text-warn border-warn/50',
  neg: 'text-neg border-neg/50',
};

const stats = [
  { label: 'Open IPOs now', value: String(open.length), sub: `${upcoming.length} upcoming` },
  { label: 'Top GMP today', value: topGmp ? rupee(topGmp.gmp) : '—', sub: topGmp?.name ?? '' },
  { label: 'Avg subscription', value: avgSub > 0 ? avgSub.toFixed(1) + 'x' : '—', sub: 'across open IPOs' },
  { label: 'GMP accuracy', value: accuracy.count ? accuracy.score + '%' : '—', sub: `${accuracy.count} listed tracked` },
];

const title = 'IPO GMP Today Live — Grey Market Premium Tracker | IPO Views';
const description = `IPO GMP today, live: ${open.length} open IPOs, top GMP ${topGmp ? rupee(topGmp.gmp) : '—'} (${topGmp?.name ?? ''}). Day-wise subscription status, allotment, SME & mainboard IPO listing-gain estimates & ${accuracy.score}% GMP accuracy.`;

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Live & Upcoming IPOs',
  itemListElement: [...open, ...upcoming].map((i, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    name: i.name,
    url: new URL(`/ipo/${i.slug}`, Astro.site).href,
  })),
};

// FAQPage structured data — mirrors the rendered accordion below.
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: HOMEPAGE_FAQS.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} jsonLd={[itemListLd, faqLd]}>
  <!-- HERO -->
  <section class="hero-surface border-b border-border">
    <div class="container-page py-10 sm:py-16">
      <div class="flex flex-wrap items-center gap-2">
        <span class={`pill border ${moodTone[mood.tone]}`}>Market sentiment: {mood.mood}</span>
        <span class="num pill border border-border text-text-muted">Avg GMP {pct(mood.avgGmpPct)} of price</span>
        <span class="num pill border border-border text-text-faint">{freshnessLabel()}</span>
        {fresh.stale && (
          <span class="num pill border border-warn/50 text-warn" title="The newest GMP edit is over 2 hours old">⚠ GMP may be stale</span>
        )}
      </div>

      <h1 class="hero-title mt-5 max-w-3xl text-balance">
        Live IPO <em class="italic text-text">Grey Market Premium</em>, tracked honestly.
      </h1>
      <p class="mt-5 max-w-2xl text-text-muted">
        Track <strong class="font-semibold text-text">IPO GMP today</strong> — live
        <a href="/learn/what-is-gmp" class="text-info hover:text-text">grey market premium</a>,
        day-wise subscription status and the most accurate
        <a href="/listed" class="text-info hover:text-text">listing gain</a> estimates for every
        mainboard &amp; SME IPO. Check the
        <a href="/calendar" class="text-info hover:text-text">IPO calendar</a> and
        <a href="/allotment" class="text-info hover:text-text">allotment status</a> — built for
        Indian retail investors.
      </p>

      <!-- stats bar: horizontal scroll on mobile, grid on desktop -->
      <div class="mt-9 flex gap-3 overflow-x-auto pb-1 sm:mt-10 sm:grid sm:grid-cols-4 sm:gap-4 sm:overflow-visible sm:pb-0 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        {stats.map((s) => (
          <div class="card min-w-[150px] shrink-0 px-4 py-4 sm:min-w-0">
            <p class="label">{s.label}</p>
            <p class="num mt-2 text-3xl font-bold leading-none">{s.value}</p>
            <p class="mt-1.5 truncate text-xs text-text-faint">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="container-page py-10 sm:py-12">
    <!-- LIVE / OPEN -->
    <section>
      <SectionHeader
        title="Live IPOs"
        subtitle="Currently open for subscription — apply before the close date."
      />
      {open.length ? (
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {open.map((ipo) => <IpoCard ipo={ipo} />)}
        </div>
      ) : (
        <p class="card p-6 text-center text-text-muted">No IPOs are open right now. Check the upcoming list below.</p>
      )}
    </section>

    <!-- UPCOMING -->
    <section class="mt-14">
      <SectionHeader
        title="Upcoming IPOs"
        subtitle="Opening within the next 30 days."
        href="/calendar"
        hrefLabel="See calendar"
      />
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {upcoming.map((ipo) => <IpoCard ipo={ipo} />)}
      </div>
    </section>

    <!-- RECENTLY LISTED: actual vs estimated -->
    <section class="mt-16">
      <SectionHeader
        title="Recently listed"
        subtitle="How our GMP-based estimate compared to the actual listing."
        href="/listed"
        hrefLabel="All listed"
      />
      <div class="overflow-x-auto rounded-[var(--radius-card)] border border-border">
        <table class="w-full min-w-[640px] text-sm">
          <thead class="bg-surface-2 text-left">
            <tr class="label">
              <th class="px-4 py-3 font-medium">IPO</th>
              <th class="px-4 py-3 text-right font-medium">Issue price</th>
              <th class="px-4 py-3 text-right font-medium">Est. listing</th>
              <th class="px-4 py-3 text-right font-medium">Actual listing</th>
              <th class="px-4 py-3 text-right font-medium">Listing gain</th>
            </tr>
          </thead>
          <tbody>
            {recentlyListed.map((i) => {
              const est = listingEstimate(i);
              const gain = listingGain(i);
              return (
                <tr class="border-t border-border hover:bg-surface-2/40">
                  <td class="px-4 py-3"><a href={`/ipo/${i.slug}`} class="font-medium hover:text-brand-hover">{i.name}</a></td>
                  <td class="num px-4 py-3 text-right">{rupee(i.priceBand.max)}</td>
                  <td class="num px-4 py-3 text-right text-text-muted">{rupee(est.likely)}</td>
                  <td class="num px-4 py-3 text-right font-semibold">{i.listingPrice != null ? rupee(i.listingPrice) : '—'}</td>
                  <td class={`num px-4 py-3 text-right font-bold ${gain != null && gain >= 0 ? 'text-pos' : 'text-neg'}`}>{gain != null ? pct(gain) : '—'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <!-- CALCULATOR -->
    <section class="mt-14">
      <SectionHeader title="Plan your application" subtitle="Estimate your listing-day profit after tax." />
      <IpoCalculator ipos={[...open, ...upcoming]} />
    </section>

    <!-- LATEST NEWS -->
    <NewsSection limit={6} />

    <!-- ABOUT THE TOOL: long-form SEO content -->
    <section class="mt-16 border-t border-border pt-10" aria-labelledby="about-tool">
      <div class="max-w-3xl">
        <h2 id="about-tool" class="page-title">IPO GMP Today — Live Grey Market Premium Tracker</h2>
        <div class="mt-5 flex flex-col gap-4 leading-relaxed text-text-muted">
          <p>
            IPO Views is a free, mobile-first <strong class="text-text">IPO GMP</strong> tracker built
            for Indian retail investors who want the grey market premium today, live, and without the
            noise. The <strong class="text-text">IPO grey market premium</strong> (GMP) is the
            unofficial price at which an IPO's shares change hands before they list on the NSE or BSE,
            and it has become the single most-watched early signal of listing-day demand. We bring that
            signal — along with subscription status, allotment timelines and listing-gain estimates —
            into one clean dashboard, with honest timestamps instead of fake "live" flashing.
          </p>

          <h3 class="mt-4 text-h3 font-semibold text-text">What is IPO GMP and why it matters</h3>
          <p>
            The IPO grey market premium tells you how much extra, over the issue price, buyers are
            willing to pay ahead of listing. A rising <strong class="text-text">IPO GMP today</strong>
            usually points to strong demand and a healthy <a href="/listed" class="text-info hover:text-text">listing gain</a>,
            while a flat or negative GMP is an early warning of a muted debut. Because grey-market quotes
            were once scattered across WhatsApp and Telegram groups, IPO Views consolidates them into one
            place so you can see how IPO GMP today compares with yesterday and follow the trend across the
            full subscription window.
          </p>

          <h3 class="mt-4 text-h3 font-semibold text-text">Live GMP for SME and Mainboard IPOs</h3>
          <p>
            Every open and upcoming IPO shows its <strong class="text-text">IPO GMP live</strong>, the
            premium as a percentage of the issue price, and a seven-day trend. We cover both
            <strong class="text-text">mainboard IPO GMP</strong> and <strong class="text-text">SME IPO GMP</strong>,
            clearly labelled, because the two behave very differently — SME issues carry larger minimum lot
            values and thinner liquidity. Whether you are checking ipo gmp today live before applying or
            researching an upcoming IPO in 2026, the numbers stay front and centre and refresh as our data
            updates.
          </p>

          <h3 class="mt-4 text-h3 font-semibold text-text">Subscription status, allotment and listing gains</h3>
          <p>
            Beyond GMP, IPO Views tracks day-wise <strong class="text-text">IPO subscription status</strong>
            across the QIB, NII and retail categories, so you can gauge real demand rather than rely on
            grey-market sentiment alone. Once bidding closes, use our
            <a href="/allotment" class="text-info hover:text-text">IPO allotment status</a> checker to look up
            your application by PAN through the official registrar. After listing, our
            <a href="/listed" class="text-info hover:text-text">listed IPOs</a> page records the actual IPO
            listing gain against our earlier GMP-based estimate and publishes a transparent accuracy score —
            because a tracker is only worth using if it is honest about how often it is right.
          </p>

          <h3 class="mt-4 text-h3 font-semibold text-text">Kostak rate, Sub2 and grey-market basics</h3>
          <p>
            New to the grey market? Our <a href="/learn" class="text-info hover:text-text">education hub</a>
            explains the <strong class="text-text">kostak rate</strong> (a fixed price paid for your entire
            application regardless of allotment), Subject to Sauda (Sub2, where payment depends on actually
            receiving an allotment), and how GMP is discovered in the first place. These terms matter if you
            plan to deal in applications rather than simply apply, and understanding them helps you read GMP
            movements with the right context.
          </p>

          <h3 class="mt-4 text-h3 font-semibold text-text">IPO calendar, news and tools</h3>
          <p>
            Use the <a href="/calendar" class="text-info hover:text-text">IPO calendar India</a> to see every
            open, close, allotment and listing date for mainboard and SME issues on one colour-coded grid, and
            the <a href="/news" class="text-info hover:text-text">latest IPO news</a> feed for headlines from
            leading Indian market sources. Our IPO calculator estimates your listing-day profit after tax, and
            the <a href="/compare" class="text-info hover:text-text">compare tool</a> lets you weigh up to three
            IPOs side by side on GMP, subscription and price band. Bookmark this page to follow every
            upcoming IPO in 2026 and check IPO GMP today before each application window closes.
          </p>

          <p class="text-sm text-text-faint">
            IPO Views is independent and free to use. Grey market premium is an unofficial,
            community-sourced indicator — it is not investment advice and is not endorsed by SEBI, the NSE
            or the BSE. Always read the prospectus and do your own research before investing.
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ (SEO + FAQPage JSON-LD) -->
    <FaqAccordion faqs={HOMEPAGE_FAQS} />
  </div>
</BaseLayout>
