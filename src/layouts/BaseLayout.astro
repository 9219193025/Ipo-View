---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** path-relative canonical override; defaults to current URL */
  canonical?: string;
  /** extra JSON-LD objects to inline (per-page structured data) */
  jsonLd?: Record<string, unknown>[];
  ogType?: string;
  /** keep this page out of search indexes (e.g. /admin) */
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  jsonLd = [],
  ogType = 'website',
  noindex = false,
} = Astro.props;

const site = Astro.site ?? new URL('https://ipoviews.com');
const canonicalURL = new URL(canonical ?? Astro.url.pathname, site).href;
const ogImage = new URL('/og-default.svg', site).href;

// Site-wide structured data (WebSite) always present.
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'IPO Views',
  url: site.href,
  description: 'Live Indian IPO GMP (Grey Market Premium) tracker',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${site.href}listed?q={query}`,
    'query-input': 'required name=query',
  },
};
const allLd = [websiteLd, ...jsonLd];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0F172A" />
    <meta name="generator" content={Astro.generator} />

    <!-- No-FOUC theme init: set data-theme before first paint. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'light' && t !== 'dark') {
            t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          }
          document.documentElement.setAttribute('data-theme', t);
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute('content', t === 'light' ? '#F7F9FC' : '#0F172A');
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- icons / PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- fonts: preconnect + display=swap for fast paint -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="IPO Views" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {allLd.map((ld) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body class="flex min-h-dvh flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-2 focus:z-[100] focus:rounded-md focus:bg-brand focus:px-3 focus:py-2 focus:text-white">Skip to content</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- PWA: register service worker for smart alerts (feature #7) -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
