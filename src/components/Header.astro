---
/** Sticky header with live "Markets Open/Closed" indicator (DESIGN.md §6). */
import { isMarketOpenIST } from '../data/helpers';

const nav = [
  { href: '/', label: 'Live GMP' },
  { href: '/listed', label: 'Listed' },
  { href: '/calendar', label: 'Calendar' },
  { href: '/compare', label: 'Compare' },
  { href: '/global', label: 'Global' },
  { href: '/allotment', label: 'Allotment' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
const openAtBuild = isMarketOpenIST();
---

<header class="sticky top-0 z-50 border-b border-border bg-surface/85 backdrop-blur-md">
  <div class="container-page flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label="IPO Views home">
      <span class="grid h-9 w-9 place-items-center rounded-md bg-brand text-sm font-bold text-white">IV</span>
      <span class="text-xl font-bold tracking-tight">IPO<span class="text-brand-hover">Views</span></span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {nav.map((n) => (
        <a
          href={n.href}
          class={`rounded-md px-3 py-1.5 text-[13px] font-medium transition-colors hover:text-text ${isActive(n.href) ? 'text-text bg-surface-2' : 'text-text-muted'}`}
          aria-current={isActive(n.href) ? 'page' : undefined}
        >{n.label}</a>
      ))}
    </nav>

    <!-- right cluster: theme toggle + market indicator + mobile menu -->
    <div class="flex items-center gap-1.5 shrink-0 sm:gap-2">
      <!-- theme toggle -->
      <button
        type="button"
        id="theme-toggle"
        class="grid h-9 w-9 place-items-center rounded-md text-text-muted transition-colors hover:bg-surface-2 hover:text-text"
        aria-label="Toggle light / dark theme"
      >
        <svg class="theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M6.3 17.7l-1.4 1.4M19.1 4.9l-1.4 1.4"/></svg>
        <svg class="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      </button>

      <span
        id="market-indicator"
        data-open={openAtBuild ? 'true' : 'false'}
        title={openAtBuild ? 'Markets Open' : 'Markets Closed'}
        class="pill border border-border text-text-muted"
      >
        <span id="market-dot" class={`inline-block h-2 w-2 rounded-full ${openAtBuild ? 'bg-pos market-dot-open' : 'bg-text-faint'}`} aria-hidden="true"></span>
        <span id="market-text" class="num hidden sm:inline">{openAtBuild ? 'Markets Open' : 'Markets Closed'}</span>
      </span>

      <button
        type="button"
        id="nav-toggle"
        class="grid h-9 w-9 place-items-center rounded-md text-text-muted hover:bg-surface-2 md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- mobile nav -->
  <nav id="mobile-nav" class="container-page hidden flex-col gap-1 pb-3 md:hidden" aria-label="Mobile">
    {nav.map((n) => (
      <a
        href={n.href}
        class={`rounded-md px-3 py-2 text-sm font-medium ${isActive(n.href) ? 'bg-surface-2 text-text' : 'text-text-muted'}`}
        aria-current={isActive(n.href) ? 'page' : undefined}
      >{n.label}</a>
    ))}
  </nav>
</header>

<script>
  // Mobile nav toggle
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    menu?.classList.toggle('flex', open);
  });

  // Theme toggle — persist choice; the no-FOUC script in <head> applies it on load.
  const themeBtn = document.getElementById('theme-toggle');
  themeBtn?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
    root.setAttribute('data-theme', next);
    try { localStorage.setItem('theme', next); } catch (e) {}
    document.querySelector('meta[name="theme-color"]')
      ?.setAttribute('content', next === 'light' ? '#F7F9FC' : '#0F172A');
  });

  // Live market-hours indicator — recompute client-side (IST), refresh each minute.
  function refreshMarket() {
    const el = document.getElementById('market-indicator');
    const dot = document.getElementById('market-dot');
    const txt = document.getElementById('market-text');
    if (!el || !dot || !txt) return;
    const ist = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Kolkata' }));
    const day = ist.getDay();
    const mins = ist.getHours() * 60 + ist.getMinutes();
    const open = day !== 0 && day !== 6 && mins >= 555 && mins <= 930; // 09:15–15:30
    dot.className = 'inline-block h-2 w-2 rounded-full ' + (open ? 'bg-pos market-dot-open' : 'bg-text-faint');
    txt.textContent = open ? 'Markets Open' : 'Markets Closed';
    el.setAttribute('title', open ? 'Markets Open' : 'Markets Closed');
    el.dataset.open = String(open);
  }
  refreshMarket();
  setInterval(refreshMarket, 60000);
</script>
