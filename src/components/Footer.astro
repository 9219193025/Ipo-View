---
const year = new Date().getFullYear();
const cols = [
  { title: 'Track', links: [
    { href: '/', label: 'Live IPO GMP' },
    { href: '/calendar', label: 'IPO Calendar' },
    { href: '/listed', label: 'Listed IPOs' },
    { href: '/compare', label: 'Compare IPOs' },
  ]},
  { title: 'Tools', links: [
    { href: '/allotment', label: 'Allotment Status' },
    { href: '/#calculator', label: 'IPO Calculator' },
    { href: '/listed#accuracy', label: 'GMP Accuracy' },
  ]},
];
---

<footer class="mt-16 border-t border-border bg-surface">
  <div class="container-page grid grid-cols-2 gap-8 py-10 sm:grid-cols-4">
    <div class="col-span-2 sm:col-span-2">
      <a href="/" class="flex items-center gap-2">
        <span class="grid h-7 w-7 place-items-center rounded-md bg-brand font-bold text-white">IV</span>
        <span class="text-base font-bold">IPO<span class="text-brand-hover">Views</span></span>
      </a>
      <p class="mt-3 max-w-xs text-sm text-text-muted">
        India's grey-market premium tracker for retail investors — live GMP, day-wise
        subscription, and the most accurate listing estimates.
      </p>
    </div>
    {cols.map((c) => (
      <div>
        <h4 class="label mb-3">{c.title}</h4>
        <ul class="flex flex-col gap-2">
          {c.links.map((l) => (
            <li><a href={l.href} class="text-sm text-text-muted transition-colors hover:text-text">{l.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="border-t border-border">
    <div class="container-page flex flex-col gap-2 py-5 text-xs text-text-faint sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} IPO Views (ipoviews.com). Sample data for demonstration.</p>
      <p class="max-w-xl">
        <strong class="text-text-muted">Disclaimer:</strong> GMP is an unofficial grey-market
        indicator, not investment advice. IPO investments are subject to market risks.
      </p>
    </div>
  </div>
</footer>
